rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // User validation
    function isValidUser(data) {
        return data.keys().hasAll(['userId', 'email', 'fullName', 'createdAt', 'updatedAt']) &&
               data.keys().hasOnly(['userId', 'email', 'fullName', 'createdAt', 'updatedAt']) &&
               data.userId == request.auth.uid &&
               data.email is string && data.email.size() <= 200 &&
               data.fullName is string && data.fullName.size() <= 100 &&
               data.createdAt == request.time &&
               data.updatedAt == request.time;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId);
      allow list: if false;
      allow create: if isSignedIn() && isValidId(userId) && userId == request.auth.uid && isValidUser(incoming());
      allow update: if isSignedIn() && isValidId(userId) && userId == request.auth.uid &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['fullName', 'updatedAt']) &&
                    incoming().fullName is string && incoming().fullName.size() <= 100 &&
                    incoming().updatedAt == request.time &&
                    incoming().userId == existing().userId &&
                    incoming().email == existing().email &&
                    incoming().createdAt == existing().createdAt;
    }

    // Product validation
    function isValidProduct(data) {
        return data.keys().hasAll(['sellerId', 'name', 'category', 'price', 'condition', 'image', 'rating', 'reviews', 'createdAt', 'updatedAt']) &&
            data.keys().hasOnly(['sellerId', 'name', 'category', 'price', 'condition', 'image', 'rating', 'reviews', 'createdAt', 'updatedAt']) &&
            data.sellerId == request.auth.uid &&
            data.name is string && data.name.size() <= 150 &&
            data.category is string && data.category.size() <= 50 &&
            data.price is number && data.price >= 0 &&
            data.condition in ['New', 'Used', 'Refurbished'] &&
            data.image is string && data.image.size() <= 1000 &&
            data.rating is number && data.rating >= 0 && data.rating <= 5 &&
            data.reviews is number && data.reviews >= 0 &&
            data.createdAt == request.time &&
            data.updatedAt == request.time;
    }

    match /products/{productId} {
        allow get: if isValidId(productId);
        allow list: if true;
        allow create: if isSignedIn() && isValidId(productId) && isValidProduct(incoming()) && exists(/databases/$(database)/documents/users/$(request.auth.uid));
        allow update: if isSignedIn() && isValidId(productId) && existing().sellerId == request.auth.uid &&
            incoming().diff(existing()).affectedKeys().hasOnly(['name', 'category', 'price', 'condition', 'image', 'updatedAt']) &&
            incoming().name is string && incoming().name.size() <= 150 &&
            incoming().category is string && incoming().category.size() <= 50 &&
            incoming().price is number && incoming().price >= 0 &&
            incoming().condition in ['New', 'Used', 'Refurbished'] &&
            incoming().image is string && incoming().image.size() <= 1000 &&
            incoming().updatedAt == request.time;
        allow delete: if isSignedIn() && isValidId(productId) && existing().sellerId == request.auth.uid;
    }

    // Order validation
    function isValidOrder(data) {
        return data.keys().hasAll(['buyerId', 'productId', 'price', 'address', 'status', 'createdAt', 'updatedAt']) &&
            data.keys().hasOnly(['buyerId', 'productId', 'price', 'address', 'status', 'createdAt', 'updatedAt']) &&
            data.buyerId == request.auth.uid &&
            data.productId is string && data.productId.size() <= 128 &&
            data.price is number && data.price >= 0 &&
            data.address is string && data.address.size() <= 500 &&
            data.status == 'pending' &&
            data.createdAt == request.time &&
            data.updatedAt == request.time;
    }

    match /orders/{orderId} {
        allow get: if isSignedIn() && isValidId(orderId) && (existing().buyerId == request.auth.uid || get(/databases/$(database)/documents/products/$(existing().productId)).data.sellerId == request.auth.uid);
        allow list: if isSignedIn() && resource.data.buyerId == request.auth.uid;
        allow create: if isSignedIn() && isValidId(orderId) && isValidOrder(incoming()) && exists(/databases/$(database)/documents/products/$(incoming().productId));
        allow update: if isSignedIn() && isValidId(orderId) &&
            get(/databases/$(database)/documents/products/$(existing().productId)).data.sellerId == request.auth.uid &&
            incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) &&
            incoming().status in ['pending', 'in_transit', 'delivered'] &&
            incoming().updatedAt == request.time;
    }
    // Vehicle validation
    function isValidVehicle(data) {
        return data.keys().hasAll(['userId', 'year', 'make', 'model', 'createdAt', 'updatedAt']) &&
               data.keys().hasOnly(['userId', 'year', 'make', 'model', 'trim', 'engine', 'isPrimary', 'images', 'videos', 'createdAt', 'updatedAt']) &&
               data.userId == request.auth.uid &&
               data.year is string && data.year.size() == 4 && data.year.matches('^[0-9]{4}$') &&
               data.make is string && data.make.size() <= 50 &&
               data.model is string && data.model.size() <= 50 &&
               (!('trim' in data) || (data.trim is string && data.trim.size() <= 50)) &&
               (!('engine' in data) || (data.engine is string && data.engine.size() <= 50)) &&
               (!('isPrimary' in data) || data.isPrimary is bool) &&
               (!('images' in data) || data.images is list) &&
               (!('videos' in data) || data.videos is list) &&
               data.createdAt == request.time &&
               data.updatedAt == request.time;
    }

    match /users/{userId}/vehicles/{vehicleId} {
        allow get: if isSignedIn() && isValidId(userId) && isValidId(vehicleId) && userId == request.auth.uid;
        allow list: if isSignedIn() && isValidId(userId) && userId == request.auth.uid;
        allow create: if isSignedIn() && isValidId(userId) && isValidId(vehicleId) && userId == request.auth.uid && isValidVehicle(incoming());
        allow update: if isSignedIn() && isValidId(userId) && isValidId(vehicleId) && userId == request.auth.uid &&
            incoming().diff(existing()).affectedKeys().hasOnly(['year', 'make', 'model', 'trim', 'engine', 'isPrimary', 'images', 'videos', 'updatedAt']) &&
            incoming().year is string && incoming().year.size() == 4 && incoming().year.matches('^[0-9]{4}$') &&
            incoming().make is string && incoming().make.size() <= 50 &&
            incoming().model is string && incoming().model.size() <= 50 &&
            (!('trim' in incoming()) || (incoming().trim is string && incoming().trim.size() <= 50)) &&
            (!('engine' in incoming()) || (incoming().engine is string && incoming().engine.size() <= 50)) &&
            (!('isPrimary' in incoming()) || incoming().isPrimary is bool) &&
            (!('images' in incoming()) || incoming().images is list) &&
            (!('videos' in incoming()) || incoming().videos is list) &&
            incoming().updatedAt == request.time;
        allow delete: if isSignedIn() && isValidId(userId) && isValidId(vehicleId) && userId == request.auth.uid;
    }
  }
}
